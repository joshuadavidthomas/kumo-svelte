{
  "name": "kumo-svelte",
  "version": "0.0.0",
  "private": false,
  "description": "Svelte 5 port of Cloudflare's Kumo component library",
  "keywords": [
    "cloudflare",
    "components",
    "design-system",
    "kumo",
    "svelte"
  ],
  "homepage": "https://github.com/joshuadavidthomas/kumo-svelte#readme",
