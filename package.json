{
  "name": "kumo-svelte-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm --filter kumo-svelte check && pnpm --filter @kumo-svelte/docs check",
    "docs:build": "pnpm --filter @kumo-svelte/docs build",
    "docs:check": "pnpm --filter @kumo-svelte/docs check",
    "docs:dev": "pnpm --filter @kumo-svelte/docs dev",
    "format": "oxfmt --write package.json pnpm-workspace.yaml tsconfig.json README.md scripts packages docs",
    "format:check": "oxfmt --check package.json pnpm-workspace.yaml tsconfig.json README.md scripts packages docs",
    "generate:registry": "pnpm --filter kumo-svelte generate:registry",
    "lint": "pnpm --filter kumo-svelte lint",
    "test": "pnpm --filter kumo-svelte test",
    "typecheck": "pnpm --filter kumo-svelte typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.1"
}
