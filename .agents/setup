#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
node_version="$(<"$repo_root/.node-version")"
install_root="$HOME/.local"
node_dir="$install_root/share/node-v$node_version"

mkdir -p "$install_root/bin" "$install_root/share"
export PATH="$install_root/bin:$PATH"

if [[ ! -x "$node_dir/bin/node" ]] || [[ "$($node_dir/bin/node --version)" != "v$node_version" ]]; then
  case "$(uname -m)" in
    x86_64) node_arch="x64" ;;
    aarch64 | arm64) node_arch="arm64" ;;
    *)
      echo "Unsupported architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac

  archive="node-v$node_version-linux-$node_arch.tar.xz"
  download_dir="$(mktemp -d)"
  trap 'rm -rf "$download_dir"' EXIT

  echo "Installing Node.js v$node_version..."
  curl -fsSLo "$download_dir/$archive" "https://nodejs.org/dist/v$node_version/$archive"
  curl -fsSLo "$download_dir/SHASUMS256.txt" "https://nodejs.org/dist/v$node_version/SHASUMS256.txt"
  (
    cd "$download_dir"
    grep "  $archive\$" SHASUMS256.txt | sha256sum --check --status
  )
  tar -xJf "$download_dir/$archive" -C "$download_dir"
  rm -rf "$node_dir"
  mv "$download_dir/node-v$node_version-linux-$node_arch" "$node_dir"
fi

for executable in node npm npx; do
  ln -sfn "$node_dir/bin/$executable" "$install_root/bin/$executable"
done

package_manager="$(node -p 'require(process.argv[1]).packageManager' "$repo_root/package.json")"
pnpm_version="${package_manager#pnpm@}"
if [[ ! -x "$install_root/bin/pnpm" ]] || [[ "$(cd / && "$install_root/bin/pnpm" --version 2>/dev/null || true)" != "$pnpm_version" ]]; then
  echo "Installing pnpm $pnpm_version..."
  npm install --global --prefix "$install_root" "$package_manager"
fi

echo "Installing workspace dependencies..."
cd "$repo_root"
pnpm install --frozen-lockfile

upstream_dir="$repo_root/.amp/upstream/kumo"
upstream_bin_dir="$repo_root/.amp/bin"
upstream_build_marker="$upstream_dir/.amp-built-sha"
upstream_ref="@cloudflare/kumo@2.8.0"

upstream_pnpm() {
  PATH="$upstream_bin_dir:$PATH" pnpm "$@"
}

echo "Preparing the managed cloudflare/kumo comparison checkout..."
mkdir -p "$(dirname "$upstream_dir")"
mkdir -p "$upstream_bin_dir"
cat >"$upstream_bin_dir/pnpm" <<EOF
#!/usr/bin/env bash
exec "$node_dir/bin/npx" -y pnpm@10.22.0 "\$@"
EOF
chmod +x "$upstream_bin_dir/pnpm"

# Avoid Astro reloading the pristine config between reset and the managed
# portal-host adjustment below. The final services ensure restarts it.
amp orb service stop kumo-react-docs >/dev/null 2>&1 || true

if [[ ! -d "$upstream_dir/.git" ]]; then
  git clone --depth=1 --branch="$upstream_ref" https://github.com/cloudflare/kumo.git "$upstream_dir"
else
  git -C "$upstream_dir" remote set-url origin https://github.com/cloudflare/kumo.git
  git -C "$upstream_dir" fetch --depth=1 origin "refs/tags/$upstream_ref"
  # This is a disposable, ignored comparison checkout owned by this setup script.
  git -C "$upstream_dir" reset --hard FETCH_HEAD
fi

upstream_astro_config="$upstream_dir/packages/kumo-docs-astro/astro.config.mjs"
node --input-type=module - "$upstream_astro_config" <<'NODE'
import { readFileSync, writeFileSync } from "node:fs";

const configPath = process.argv[2];
const allowedHosts = '    server: { allowedHosts: [".e2b.app", ".onamp.dev"] },\n';
const viteMarker = "  vite: {\n";
const source = readFileSync(configPath, "utf8");

if (!source.includes(allowedHosts)) {
  const matches = source.split(viteMarker).length - 1;
  if (matches !== 1) {
    throw new Error(`Expected one Vite config block in ${configPath}, found ${matches}`);
  }
  writeFileSync(configPath, source.replace(viteMarker, viteMarker + allowedHosts));
}
NODE

upstream_sha="$(git -C "$upstream_dir" rev-parse HEAD)"
if [[ ! -f "$upstream_build_marker" ]] ||
  [[ "$(cat "$upstream_build_marker")" != "$upstream_sha" ]] ||
  [[ ! -f "$upstream_dir/packages/kumo/dist/index.js" ]]; then
  echo "Installing and generating upstream Kumo docs at ${upstream_sha:0:7}..."
  upstream_pnpm --dir "$upstream_dir" install --frozen-lockfile
  upstream_pnpm --dir "$upstream_dir" codegen
  upstream_pnpm --dir "$upstream_dir" --filter @cloudflare/kumo build
  printf '%s\n' "$upstream_sha" >"$upstream_build_marker"
else
  echo "Upstream Kumo ${upstream_sha:0:7} is already built."
fi

echo "Starting supervised local and upstream documentation services..."
amp orb services ensure

echo "Orb setup complete (Node.js $(node --version), pnpm $(pnpm --version))."
