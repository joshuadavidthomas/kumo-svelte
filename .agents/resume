#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
expected_node="v$(<"$repo_root/.node-version")"
package_manager="$(node -p 'require(process.argv[1]).packageManager' "$repo_root/package.json")"
expected_pnpm="${package_manager#pnpm@}"
pnpm_bin="$HOME/.local/bin/pnpm"

if [[ "$(node --version 2>/dev/null || true)" != "$expected_node" ]]; then
  echo "Expected Node.js $expected_node; rerun .agents/setup." >&2
  exit 1
fi

if [[ ! -x "$pnpm_bin" ]] || [[ "$(cd / && "$pnpm_bin" --version 2>/dev/null || true)" != "$expected_pnpm" ]]; then
  echo "Expected pnpm $expected_pnpm; rerun .agents/setup." >&2
  exit 1
fi

mkdir -p "$repo_root/.amp"

# Keep this in the foreground. Amp stops waiting after ten seconds and lets a
# slower service recovery continue while preserving diagnostics for the agent.
amp orb services ensure >"$repo_root/.amp/services-resume.log" 2>&1

echo "Orb prerequisites and comparison services are ready."
