{
  "name": "@kumo-svelte/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api-docs:generate": "node scripts/generate-api-docs.mjs && oxfmt --write src/lib/generated/api-docs.ts",
    "build": "pnpm api-docs:generate && vite build",
    "check": "pnpm api-docs:generate && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "dev": "pnpm api-docs:generate && vite dev",
    "preview": "vite preview"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "echarts": "^6.0.0",
    "kumo-svelte": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.0",
    "mdsvex": "^0.12.7",
    "phosphor-svelte": "^3.1.0",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0",
    "vite": "^8.0.8",
    "wrangler": "^4.106.0"
  }
}
