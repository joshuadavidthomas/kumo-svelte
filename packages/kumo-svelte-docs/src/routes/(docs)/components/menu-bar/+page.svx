## Installation

### Barrel

```ts
import { MenuBar } from "kumo-svelte";
```

### Granular

```ts
import { MenuBar } from "kumo-svelte/components/menubar";
```

## Usage

```svelte
<script lang="ts">
  import TextBIcon from "phosphor-svelte/lib/TextBIcon";
  import { MenuBar } from "kumo-svelte";

  let active = $state<string | undefined>("bold");
</script>

{#snippet boldIcon()}
  <TextBIcon />
{/snippet}

<MenuBar
  isActive={active}
  optionIds
  options={[
    {
      icon: boldIcon,
      id: "bold",
      tooltip: "Bold",
      onSelect: () => {
        active = active === "bold" ? undefined : "bold";
      },
    },
  ]}
/>
```

