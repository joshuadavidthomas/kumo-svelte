## Installation

### Barrel

```ts
import { Loader } from "kumo-svelte/components/loader";
```

### Granular

```ts
import { Loader } from "kumo-svelte/components/loader";
```

## Usage

```svelte
<script lang="ts">
  import { Loader } from "kumo-svelte/components/loader";
</script>

<Loader />
```

