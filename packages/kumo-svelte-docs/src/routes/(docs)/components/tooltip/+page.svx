## Installation

### Barrel

```ts
import { Tooltip } from "kumo-svelte";
```

### Granular

```ts
import * as Tooltip from "kumo-svelte/components/tooltip";
```

## Usage

```svelte
<script lang="ts">
  import { Button, Tooltip } from "kumo-svelte";
</script>

<Tooltip.Provider>
  <Tooltip content="Tooltip text">
    {#snippet render({ props })}
      <Button {...props}>Hover me</Button>
    {/snippet}
  </Tooltip>
</Tooltip.Provider>
```

For delay grouping across multiple tooltips, see [TooltipProvider](#tooltipprovider).

