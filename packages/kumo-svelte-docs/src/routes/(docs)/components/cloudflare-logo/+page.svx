## Installation

### Barrel

```ts
import { CloudflareLogo, PoweredByCloudflare, generateCloudflareLogoSvg } from "kumo-svelte/components/cloudflare-logo";
```

### Granular

```ts
import {
  CloudflareLogo,
  PoweredByCloudflare,
  generateCloudflareLogoSvg,
} from "kumo-svelte/components/cloudflare-logo";
```

## Usage

```svelte
<script lang="ts">
  import { CloudflareLogo } from "kumo-svelte/components/cloudflare-logo";
</script>

<CloudflareLogo class="w-36" />
```

## Examples

### Glyph Only

Use `variant="glyph"` to display just the cloud icon without the wordmark.

