## Installation

### Barrel

```ts
import { Button } from "kumo-svelte";
```

### Granular

```ts
import { Button } from "kumo-svelte/components/button";
```

## Usage

```svelte
<script lang="ts">
  import { Button } from "kumo-svelte";
</script>

<Button variant="secondary">Click me</Button>
```

