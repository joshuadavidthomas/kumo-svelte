## Installation

### Barrel

```ts
import { Badge } from "kumo-svelte";
```

### Granular

```ts
import { Badge } from "kumo-svelte/components/badge";
```

## Usage

```svelte
<script lang="ts">
  import { Badge } from "kumo-svelte";
</script>

<Badge variant="secondary">New</Badge>
```

